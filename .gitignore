# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js — every variant. Build caches can contain baked-in env-var
# secrets (notably turbopack .sst caches), so these MUST stay ignored.
/.next/
/.next-*
.next/
.next-*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev*.log
dev*.err
*.err

# scratch/temp local files
fetched.html
guide.html
root.html
git-path.txt
node-procs.txt
test-write.txt

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
public/globe highres posterized.png
public/globe highres posterized2.png
